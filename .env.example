# ─────────────────────────────────────────────────────────────────────────────
# MathCariola — Environment Variables
# Copy this file to .env.local and fill in the values for local development.
# In Vercel, add these via Project Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────────────────

# Base URL used for Open Graph image absolute URLs and sitemap.
# In production, set this to your Vercel deployment URL.
# Default fallback: https://mathcariola.vercel.app
NEXT_PUBLIC_BASE_URL=https://mathcariola.vercel.app
